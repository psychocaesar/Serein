<?xml version="1.0" encoding="utf-8"?>
<!--
  AndroidManifest.xml — Serein
  Emplacement dans le projet : android/app/src/main/AndroidManifest.xml

  Philosophie :
  - Permissions minimales (privacy-first)
  - Notifications locales (rappel quotidien uniquement — pas de push serveur)
  - Lecture audio en arrière-plan (écran verrouillé)
  - Compatible Android 8+ (API 26)
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ══════════════════════════════════════════════════
         PERMISSIONS
         Uniquement celles strictement nécessaires.
    ══════════════════════════════════════════════════ -->

    <!-- Accès réseau pour charger les audios non encore mis en cache -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Vérifier la connectivité avant de tenter un téléchargement -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Lecture audio en arrière-plan / écran verrouillé.
         Requiert un ForegroundService déclaré ci-dessous. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Empêche Android d'endormir le CPU pendant la lecture audio.
         Utilisé par Capacitor WebView automatiquement. -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Notifications locales (rappel quotidien) -->
    <!-- POST_NOTIFICATIONS requis sur Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Permet de reprogrammer le rappel après un redémarrage de l'appareil -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Pas de SCHEDULE_EXACT_ALARM : un rappel quotidien tolère quelques minutes
         d'imprécision, et le Play Store exige une justification pour les alarmes
         exactes depuis Android 14. Le plugin retombe sur une alarme inexacte. -->

    <!-- ══════════════════════════════════════════════════
         DÉCLARATION DE L'APPLICATION
    ══════════════════════════════════════════════════ -->
    <application
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:usesCleartextTraffic="false"
        android:networkSecurityConfig="@xml/network_security_config">

        <!--
            allowBackup="false" : les données locales (stats, préférences) ne
            sont pas sauvegardées sur les serveurs Google. Cohérent avec la
            politique de confidentialité de Serein.

            usesCleartextTraffic="false" : force HTTPS sur toutes les
            connexions réseau (complète androidScheme: "https" de Capacitor).
        -->

        <!-- ── Activité principale (WebView Capacitor) ── -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode"
            android:windowSoftInputMode="adjustResize">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- ── Service de lecture audio en arrière-plan ──
             Permet la lecture quand l'écran est verrouillé.
             Le type "mediaPlayback" est requis depuis Android 10 (API 29)
             pour ce cas d'usage précis.
        -->
        <service
            android:name=".AudioPlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- ── Receiver pour reprogrammer les alarmes après redémarrage ── -->
        <receiver
            android:name="com.capacitorjs.plugins.localnotifications.LocalNotificationRestoreReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

    <!-- minSdk et targetSdk définis dans variables.gradle — ne pas redéclarer ici -->

</manifest>
