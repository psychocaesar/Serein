#!/bin/sh
# Garde app/android/app/src/main/assets/public/ (gitignoré) synchro avec
# app/pwa/ après chaque commit, pour éviter de builder une APK avec un
# web asset périmé dans Android Studio (cf. footgun 2026-06-30 : Android
# Studio avait compilé un index.html resté en 1.2.1 alors que le code
# source et les commits étaient déjà en 1.3.0).
cd "$(git rev-parse --show-toplevel)" || exit 0
if [ -f package.json ] && [ -d app/android ]; then
  echo "post-commit: npx cap sync android"
  npx cap sync android
fi
